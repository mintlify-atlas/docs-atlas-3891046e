  "keyFeatures": [
    "Multi-level document routing with TF-IDF and density indexing",
    "RAG-based Q&A system with Ollama integration",
    "LRU response cache with 1-hour TTL",
    "JSONL quality monitoring with hallucination detection",
    "Document conversion pipeline (Word/PDF/Excel)",
    "Chunk-based retrieval with sliding window overlap",
    "Web-based chat interface with streaming responses",
    "Health monitoring and automatic model warm-up"
