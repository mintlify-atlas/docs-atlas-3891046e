  "publicApiSurface": [
    "POST /siaa/chat - Main chat endpoint with streaming responses",
    "GET /siaa/status - System health and statistics",
    "GET /siaa/ver/<nombre_doc> - View document content",
    "GET /siaa/recargar - Reload document index",
    "GET /siaa/cache - Cache statistics",
    "DELETE /siaa/cache - Clear cache",
    "GET /siaa/log - Quality monitoring logs",
    "GET /siaa/keywords/<nombre_doc> - Document keywords",
    "GET /siaa/densidad/<termino> - Term density lookup",
    "GET /siaa/enrutar - Test document routing",
    "GET /siaa/fragmento - Test fragment extraction",
    "convertidor.py - Document conversion utility",
    "convertidor_pdf.py - PDF-specific converter"
  ]
